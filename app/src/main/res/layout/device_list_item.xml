<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:padding="8dp">

    <ImageView
        android:id="@+id/device_preview"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_centerHorizontal="true"
        android:scaleType="centerCrop"
        android:background="#323540"
        android:contentDescription="Device Preview" />

    <TextView
        android:id="@+id/device_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="8dp"
        android:text="Device Name"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <View
        android:id="@+id/connection_status"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_alignTop="@id/device_preview"
        android:layout_alignRight="@id/device_preview"
        android:layout_marginTop="8dp"
        android:layout_marginRight="8dp"
        android:background="@drawable/circle_shape"
        android:contentDescription="Connection Status" />

</RelativeLayout>